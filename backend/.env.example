# Server
PORT=3000
NODE_ENV=development
# 0 en accès direct local ; 1 derrière le reverse proxy Render.
TRUST_PROXY_HOPS=0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/myactivities

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting (auth brute force: 5 attempts / 15 min)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# CORS
CORS_ORIGIN=http://localhost:8081

# Base des liens dans les emails de vérification / reset.
# Les pages /verify-email et /reset-password sont servies par ce backend :
# en local → http://localhost:3000 ; en prod → URL Render du backend.
APP_URL=http://localhost:3000

# Fournisseur d'email : smtp (défaut) ou brevo-api (API HTTP, nécessite BREVO_API_KEY)
# EMAIL_PROVIDER=smtp
# BREVO_API_KEY=

# SMTP (optionnel en dev — sans SMTP_HOST, les liens sont seulement loggés en console)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=MyActivities <noreply@myactivities.app>
# Passer à true lorsque l'interface d'administration sera prête.
ACTIVITY_MODERATION_ENABLED=false
