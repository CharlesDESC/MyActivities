# Copier ce fichier en .env et remplir les valeurs

# URL de base de l'API backend (sans slash final)
EXPO_PUBLIC_API_URL=http://localhost:3000/v1

# Token public Mapbox (pk.…) — https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=

# Token secret Mapbox (sk.…, scope downloads:read) — requis pour les builds natifs (run:android / EAS)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
